@page "{attachmentId:guid}"
@model Licenta.Pages.Doctor.Appointments.ApprovalDetailsModel
@{
    ViewData["Title"] = "Review Appointment Request";
}

@section Styles {
    <link rel="stylesheet" href="~/css/approvalsdr.css" asp-append-version="true" />
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-1">Review Appointment Request</h3>
            <p class="text-muted mb-0">Approve or reject the patient's appointment request.</p>
        </div>
        <a asp-page="/Doctor/Appointments/Approvals" class="btn btn-outline-secondary">
            Back
        </a>
    </div>

    @if (TempData["StatusMessage"] is string status)
    {
        <div class="alert alert-info border-0 shadow-sm">@status</div>
    }

    @if (!Model.CanView)
    {
        <div class="alert alert-warning border-0 shadow-sm">
            You cannot view this request.
        </div>
    }
    else
    {
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <strong>Patient</strong>
                        <div>@Model.PatientName</div>
                    </div>
                    <div class="col-md-6">
                        <strong>Doctor</strong>
                        <div>@Model.DoctorName</div>
                    </div>
                    <div class="col-md-6">
                        <strong>Submitted</strong>
                        <div>@Model.UploadedAtDisplay</div>
                    </div>
                    <div class="col-md-6">
                        <strong>Requested slot</strong>
                        <div>@Model.RequestedSlotDisplay</div>
                    </div>
                    <div class="col-12">
                        <strong>Reason</strong>
                        <div>@Model.Reason</div>
                    </div>
                </div>
            </div>
        </div>

        <form method="post" asp-page-handler="Approve" class="card border-0 shadow-sm mb-3">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Approve Request</h5>

                <div class="mb-3">
                    <label class="form-label">Location</label>
                    <input asp-for="Location" class="form-control" placeholder="Clinic / Office / Room..." />
                    <span asp-validation-for="Location" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label">Optional note</label>
                    <input asp-for="DecisionNote" class="form-control" placeholder="Optional note..." />
                    <span asp-validation-for="DecisionNote" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-success">Approve</button>
                <a asp-page="/Doctor/Appointments/Approvals" class="btn btn-outline-secondary ms-2">Cancel</a>
            </div>
        </form>

        <form method="post" asp-page-handler="Reject" class="card border-0 shadow-sm">
            <div class="card-body">
                <h5 class="fw-bold mb-3">Reject Request</h5>

                <div class="mb-3">
                    <label class="form-label">Reason</label>
                    <input asp-for="DecisionNote" class="form-control" placeholder="Reason for rejection..." />
                    <span asp-validation-for="DecisionNote" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-danger">Reject</button>
            </div>
        </form>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}