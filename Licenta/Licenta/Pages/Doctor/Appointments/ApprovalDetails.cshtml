@page
@model Licenta.Pages.Doctor.Appointments.ApprovalDetailsModel
@{
    ViewData["Title"] = "Approval Details";
}

@section Styles {
    <link rel="stylesheet" href="~/css/approvaldetails.css" asp-append-version="true" />
}

<div class="approval-wrapper">
    <div class="approval-container">
        <div class="approval-header">
            <div class="header-left">
                <div class="header-badge">
                    <i class="bi bi-clipboard-check-fill"></i>
                </div>
                <div>
                    <h1 class="header-title">Approval Details</h1>
                    <p class="header-subtitle">Review and confirm the patient's appointment request</p>
                </div>
            </div>
            <a asp-page="/Doctor/Appointments/Approvals" class="btn-link-back">
                <i class="bi bi-arrow-left"></i> Back to List
            </a>
        </div>

        @if (TempData["StatusMessage"] is string status)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle-fill"></i>
                <span>@status</span>
            </div>
        }

        @if (Model.Item == null)
        {
            <div class="alert alert-error">
                <i class="bi bi-exclamation-circle-fill"></i>
                <span>Appointment request not found</span>
            </div>
        }
        else
        {
            <div class="info-grid">
             
                <div class="info-card">
                    <div class="card-icon patient-icon">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <div class="card-content">
                        <h3>Patient Information</h3>
                        <div class="info-item">
                            <span class="info-key">Name</span>
                            <span class="info-val">@Model.Item.PatientName</span>
                        </div>
                        <div class="info-item">
                            <span class="info-key">Submitted</span>
                            <span class="info-val">@Model.Item.UploadedAtLocal</span>
                        </div>
                    </div>
                </div>

          
                <div class="info-card">
                    <div class="card-icon appointment-icon">
                        <i class="bi bi-calendar-event-fill"></i>
                    </div>
                    <div class="card-content">
                        <h3>Appointment Details</h3>
                        <div class="info-item">
                            <span class="info-key">Requested Date & Time</span>
                            <span class="info-val time-badge">
                                <i class="bi bi-calendar-check-fill"></i>
                                @Model.Item.RequestedDisplay
                            </span>
                        </div>
                        <div class="info-item">
                            <span class="info-key">Reason</span>
                            <span class="info-val reason">@Model.Item.Reason</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="action-section">
                <div class="action-header">
                    <h2>Make a Decision</h2>
                    <p>Choose to approve or reject this appointment request</p>
                </div>

                <form method="post" class="action-form">
                    <input type="hidden" asp-for="AttachmentId" />

                    <div class="button-group">
                        <button type="submit" asp-page-handler="Approve" class="btn btn-approve">
                            <span class="btn-icon"><i class="bi bi-check-circle-fill"></i></span>
                            <span class="btn-text">
                                <span class="btn-label">Approve & Schedule</span>
                                <span class="btn-desc">Confirm and add to schedule</span>
                            </span>
                            <span class="btn-arrow"><i class="bi bi-arrow-right"></i></span>
                        </button>

                        <button type="submit" asp-page-handler="Reject" class="btn btn-reject" data-confirm="true">
                            <span class="btn-icon"><i class="bi bi-x-circle-fill"></i></span>
                            <span class="btn-text">
                                <span class="btn-label">Reject Request</span>
                                <span class="btn-desc">Decline this appointment</span>
                            </span>
                            <span class="btn-arrow"><i class="bi bi-arrow-right"></i></span>
                        </button>
                    </div>
                </form>
            </div>

            <div class="modal-overlay" id="confirmModal">
                <div class="modal-box">
                    <div class="modal-icon">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                    </div>
                    <h3 class="modal-title">Confirm Rejection</h3>
                    <p class="modal-text">Are you sure you want to reject this appointment request?</p>
                    <p class="modal-hint">This action cannot be undone.</p>

                    <div class="modal-actions">
                        <button type="button" class="btn btn-ghost" id="cancelModal">Cancel</button>
                        <button type="button" class="btn btn-danger-solid" id="confirmReject">Reject Request</button>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/approvaldetails.js" asp-append-version="true"></script>
}