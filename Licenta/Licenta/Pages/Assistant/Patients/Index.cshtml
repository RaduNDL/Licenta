@page
@model Licenta.Pages.Assistant.Patients.IndexModel
@{
    ViewData["Title"] = "Patients Registry";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/assistant_patients.css" asp-append-version="true" />
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold text-dark mb-1">
                <i class="bi bi-people-fill text-primary me-2"></i>Patient Registry
            </h2>
            <p class="text-muted mb-0">View and manage registered patients.</p>
        </div>
        <div>
            <span class="badge bg-white text-secondary shadow-sm px-3 py-2 border">
                Total Patients: @Model.Patients.Count()
            </span>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-header bg-white py-3 border-bottom">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="mb-0 fw-bold text-dark">All Patients</h5>
                </div>
                <div class="col-md-6">
                    <div class="input-group">
                        <span class="input-group-text bg-light border-end-0 text-secondary">
                            <i class="bi bi-search"></i>
                        </span>
                        <input type="text" id="patientSearch" class="form-control bg-light border-start-0" placeholder="Search by name or email...">
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            @if (!Model.Patients.Any())
            {
                <div class="text-center py-5">
                    <div class="mb-3">
                        <i class="bi bi-person-x text-muted" style="font-size: 3rem;"></i>
                    </div>
                    <h5 class="fw-bold text-secondary">No patients found</h5>
                    <p class="text-muted">The patient database is currently empty.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 custom-table" id="patientsTable">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Patient Name</th>
                                <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Contact Email</th>
                                <th class="text-end pe-4 text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Patients)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-initials bg-gradient-info text-white me-3">
                                                @((p.User.FullName ?? "?").Substring(0, 1).ToUpper())
                                            </div>
                                            <div class="d-flex flex-column">
                                                <span class="fw-bold text-dark">@p.User.FullName</span>
                                                <span class="text-xs text-muted">ID: @p.User.Id.ToString().Substring(0, 8)...</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <i class="bi bi-envelope text-muted me-2"></i>
                                            <a href="mailto:@p.User.Email" class="text-dark text-decoration-none fw-semibold">
                                                @p.User.Email
                                            </a>
                                        </div>
                                    </td>
                                    <td class="text-end pe-4">
                                        <span class="badge bg-success-soft text-success">
                                            <i class="bi bi-check-circle-fill me-1"></i> Active
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/assistant_patients.js" asp-append-version="true"></script>
}