@page
@model Licenta.Pages.Assistant.AssistantPanel.IndexModel
@{
    ViewData["Title"] = "Triage Center";
}

@section Styles {
    <link rel="stylesheet" href="~/css/assistantpanel.css" asp-append-version="true" />
}

<div class="assistant-dashboard py-4">
    <div class="dashboard-header mb-5">
        <div class="header-content">
            <h1 class="display-5 fw-bold greeting-text">Welcome back, <span>@Model.AssistantName</span></h1>
            <p class="subtitle"><i class="bi bi-shield-check-fill"></i> Clinic Triage Hub</p>
        </div>
        <div class="header-actions">
            <button class="btn btn-modern-refresh"><i class="bi bi-arrow-clockwise"></i> Refresh</button>
        </div>
    </div>

    <div class="row g-4 mb-5 stats-row">
        <div class="col-xl-3 col-sm-6">
            <div class="modern-stat-card card-new">
                <div class="card-icon"><i class="bi bi-inbox-fill"></i></div>
                <div class="card-info">
                    <h5>New Inquiries</h5>
                    <h2>@Model.NewInquiriesCount</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="modern-stat-card card-triage">
                <div class="card-icon"><i class="bi bi-activity"></i></div>
                <div class="card-info">
                    <h5>In Triage</h5>
                    <h2>@Model.ActiveTriageCount</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="modern-stat-card card-escalated">
                <div class="card-icon"><i class="bi bi-exclamation-triangle-fill"></i></div>
                <div class="card-info">
                    <h5>Escalated</h5>
                    <h2>@Model.EscalatedToDoctorCount</h2>
                </div>
            </div>
        </div>
        <div class="col-xl-3 col-sm-6">
            <div class="modern-stat-card card-unread">
                <div class="card-icon"><i class="bi bi-chat-dots-fill"></i></div>
                <div class="card-info">
                    <h5>Unread</h5>
                    <h2>@Model.UnreadMessagesCount</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 content-row">
        <div class="col-lg-8">
            <div class="modern-card main-table-card">
                <div class="modern-card-header">
                    <h4 class="fw-bold m-0">Recent Inquiries</h4>
                    <a asp-page="/Assistant/Messages/Requests/Index" class="btn btn-modern-outline">View All</a>
                </div>
                <div class="modern-card-body p-0">
                    <div class="table-responsive">
                        <table class="table modern-table mb-0">
                            <thead>
                                <tr>
                                    <th>Patient</th>
                                    <th>Subject</th>
                                    <th>Status</th>
                                    <th class="text-end">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.RecentRequests)
                                {
                                    <tr class="table-row-hover">
                                        <td>
                                            <div class="patient-cell">
                                                <div class="patient-avatar">@r.PatientName.Substring(0, 1).ToUpper()</div>
                                                <div class="patient-details">
                                                    <span class="patient-name">@r.PatientName</span>
                                                    <span class="time-ago">@r.TimeAgo</span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="align-middle fw-medium">@r.Subject</td>
                                        <td class="align-middle">
                                            <span class="modern-badge status-@(r.Status.ToLower().Replace(" ", "-"))">@r.Status</span>
                                        </td>
                                        <td class="text-end align-middle">
                                            <a asp-page="/Assistant/Messages/Inbox" asp-route-requestId="@r.RequestId" class="btn btn-modern-action">Chat</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="modern-card quick-actions-card mb-4">
                <div class="modern-card-header">
                    <h4 class="fw-bold m-0">Quick Actions</h4>
                </div>
                <div class="modern-card-body">
                    <div class="d-flex flex-column gap-3">
                        <a asp-page="/Assistant/Messages/Inbox" class="modern-btn-primary">
                            <i class="bi bi-chat-right-text-fill"></i> Open Triage Inbox
                        </a>
                        <a asp-page="/Assistant/Patients/Index" class="modern-btn-secondary">
                            <i class="bi bi-people-fill"></i> Patient Directory
                        </a>
                    </div>
                </div>
            </div>

            <div class="modern-card alerts-card">
                <div class="modern-card-header">
                    <h4 class="fw-bold m-0">Recent Alerts</h4>
                </div>
                <div class="modern-card-body p-0">
                    <div class="modern-alert-list">
                        @foreach (var n in Model.RecentNotifications)
                        {
                            <div class="modern-alert-item">
                                <div class="alert-indicator"></div>
                                <div class="alert-content">
                                    <div class="alert-top">
                                        <span class="alert-type">@n.Type</span>
                                        <span class="alert-time">@n.TimeAgo</span>
                                    </div>
                                    <p class="alert-message">@n.Message</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/assistantpanel.js" asp-append-version="true"></script>
}