@page
@model Licenta.Pages.Doctor.IndexModel
@{
    ViewData["Title"] = "Future Dashboard";
    var todayLabel = DateTime.Now.ToString("D");
}

@section Styles {
    <link rel="stylesheet" href="~/css/drdashboard.css" asp-append-version="true" />
}

<div class="future-container">
    <div class="glass-header">
        <div class="header-text">
            <div class="greeting-wrapper">
                <span class="pulse-dot"></span>
                <h1>Welcome, Dr. @Model.DoctorName</h1>
            </div>
            <p class="subtitle">System Operational &bull; <span id="currentDate">@todayLabel</span></p>
        </div>
        <div class="header-stats">
            <div class="stat-badge">
                <i class="bi bi-activity"></i>
                <span>Online</span>
            </div>
        </div>
    </div>

    @if (TempData["StatusMessage"] is string status)
    {
        <div class="glass-alert">
            <i class="bi bi-info-circle-fill"></i> @status
            <button type="button" class="close-btn" onclick="this.parentElement.remove()">×</button>
        </div>
    }

    <div class="bento-grid">

        <div class="glass-card card-blue">
            <div class="card-glow"></div>
            <div class="card-header">
                <div class="header-left">
                    <div class="icon-box"><i class="bi bi-calendar-event"></i></div>
                    <h3>Appointments</h3>
                </div>
                <span class="count-badge">@Model.AppointmentsTodayCount</span>
            </div>
            <div class="card-body">
                <a asp-page="/Doctor/Appointments/Index" class="nav-item">
                    <span>Calendar</span>
                    <i class="bi bi-arrow-right-short"></i>
                </a>
                <a asp-page="/Doctor/Appointments/Approvals" class="nav-item">
                    <span>Pending Approvals</span>
                    @if (Model.PendingApprovalsCount > 0)
                    {
                        <span class="nav-badge">@Model.PendingApprovalsCount</span>
                    }
                    <i class="bi bi-check-circle"></i>
                </a>
                <a asp-page="/Doctor/Appointments/RescheduleApprovals" class="nav-item">
                    <span>Reschedule Requests</span>
                    @if (Model.PendingRescheduleApprovalsCount > 0)
                    {
                        <span class="nav-badge">@Model.PendingRescheduleApprovalsCount</span>
                    }
                    <i class="bi bi-arrow-repeat"></i>
                </a>
            </div>
        </div>

        <div class="glass-card card-red">
            <div class="card-glow"></div>
            <div class="card-header">
                <div class="header-left">
                    <div class="icon-box"><i class="bi bi-cpu-fill"></i></div>
                    <h3>AI Predictions</h3>
                </div>
            </div>
            <div class="card-body">
                <a asp-page="/Doctor/Predictions/Index" class="nav-item">
                    <span>Dashboard</span>
                    <i class="bi bi-speedometer2"></i>
                </a>
                <a asp-page="/Doctor/Predictions/CBISDDSM" class="nav-item">
                    <span>Run CBIS-DDSM</span>
                    <i class="bi bi-robot"></i>
                </a>
                <a asp-page="/Doctor/Predictions/FromAttachment" class="nav-item">
                    <span>From Attachment</span>
                    <i class="bi bi-file-earmark-medical"></i>
                </a>
                <a asp-page="/Doctor/Predictions/Launch" class="nav-item">
                    <span>Launch Model</span>
                    <i class="bi bi-rocket-takeoff"></i>
                </a>
                <a asp-page="/Doctor/Predictions/Record" class="nav-item">
                    <span>Record Analysis</span>
                    <i class="bi bi-mic"></i>
                </a>
            </div>
        </div>

        <div class="glass-card card-green">
            <div class="card-glow"></div>
            <div class="card-header">
                <div class="header-left">
                    <div class="icon-box"><i class="bi bi-file-medical"></i></div>
                    <h3>Medical Records</h3>
                </div>
            </div>
            <div class="card-body">
                <a asp-page="/Doctor/MedicalRecords/Index" class="nav-item">
                    <span>All Records</span>
                    <i class="bi bi-archive"></i>
                </a>
                <a asp-page="/Doctor/MedicalRecords/Create" class="nav-item">
                    <span>Create Record</span>
                    <i class="bi bi-plus-lg"></i>
                </a>
            </div>
        </div>

        <div class="glass-card card-orange">
            <div class="card-glow"></div>
            <div class="card-header">
                <div class="header-left">
                    <div class="icon-box"><i class="bi bi-paperclip"></i></div>
                    <h3>Attachments</h3>
                </div>
                @if (Model.PendingValidationsCount > 0)
                {
                    <span class="count-badge" style="color: var(--neon-orange)">@Model.PendingValidationsCount</span>
                }
            </div>
            <div class="card-body">
                <a asp-page="/Doctor/Attachments/Inbox" class="nav-item">
                    <span>Inbox (Pending)</span>
                    @if (Model.PendingValidationsCount > 0)
                    {
                        <span class="nav-badge">@Model.PendingValidationsCount</span>
                    }
                    <i class="bi bi-inbox"></i>
                </a>
                <a asp-page="/Doctor/Attachments/Index" class="nav-item">
                    <span>All Attachments</span>
                    <i class="bi bi-collection"></i>
                </a>
                <a asp-page="/Doctor/Attachments/Upload" class="nav-item">
                    <span>Upload New</span>
                    <i class="bi bi-cloud-arrow-up"></i>
                </a>
            </div>
        </div>

        <div class="glass-card card-purple">
            <div class="card-glow"></div>
            <div class="card-header">
                <div class="header-left">
                    <div class="icon-box"><i class="bi bi-people-fill"></i></div>
                    <h3>Patients</h3>
                </div>
                <span class="count-badge">@Model.TotalPatientsCount</span>
            </div>
            <div class="card-body">
                <a asp-page="/Doctor/Patients/Index" class="nav-item">
                    <span>Patient Directory</span>
                    <i class="bi bi-search"></i>
                </a>
            </div>
        </div>

        <div class="glass-card card-cyan">
            <div class="card-glow"></div>
            <div class="card-header">
                <div class="header-left">
                    <div class="icon-box"><i class="bi bi-dna"></i></div>
                    <h3>Lab Results</h3>
                </div>
            </div>
            <div class="card-body">
                <a asp-page="/Doctor/LabResults/Index" class="nav-item">
                    <span>View Results</span>
                    <i class="bi bi-clipboard-data"></i>
                </a>
                <a asp-page="/Doctor/LabResults/Analyze" class="nav-item">
                    <span>Analyze Data</span>
                    <i class="bi bi-graph-up"></i>
                </a>
            </div>
        </div>

        <div class="glass-card card-indigo">
            <div class="card-glow"></div>
            <div class="card-header">
                <div class="header-left">
                    <div class="icon-box"><i class="bi bi-clock-history"></i></div>
                    <h3>Schedule</h3>
                </div>
            </div>
            <div class="card-body">
                <a asp-page="/Doctor/Schedule/Index" class="nav-item">
                    <span>Manage Availability</span>
                    <i class="bi bi-calendar-check"></i>
                </a>
                @if (Model.UpcomingAppointments != null && Model.UpcomingAppointments.Any())
                {
                    <div style="margin-top: auto; padding-top:12px; border-top: 1px solid rgba(255,255,255,0.1)">
                        <span style="color: var(--text-muted); font-size: 0.8rem;">Next Appointment:</span>
                        <div style="color: var(--text-main); font-weight: 600;">
                            @Model.UpcomingAppointments.First().ScheduledAt.ToString("HH:mm") -
                            @(Model.UpcomingAppointments.First().Patient?.User?.FullName ?? "Patient")
                        </div>
                    </div>
                }
            </div>
        </div>

        <div class="glass-card card-gray">
            <div class="card-glow"></div>
            <div class="card-header">
                <div class="header-left">
                    <div class="icon-box"><i class="bi bi-chat-dots-fill"></i></div>
                    <h3>Messages</h3>
                </div>
                @if (Model.UnreadMessagesCount > 0)
                {
                    <span class="count-badge">@Model.UnreadMessagesCount</span>
                }
            </div>
            <div class="card-body">
                <a asp-page="/Doctor/Messages/Inbox" class="nav-item">
                    <span>Inbox</span>
                    <i class="bi bi-envelope"></i>
                </a>
                <a asp-page="/Doctor/Messages/Requests" class="nav-item">
                    <span>Requests</span>
                    <i class="bi bi-send"></i>
                </a>
            </div>
        </div>

    </div>
</div>

@section Scripts {
    <script src="~/js/drdashboard.js"></script>
}