@page
@model Licenta.Pages.Doctor.DoctorProfile.IndexModel
@{
    ViewData["Title"] = "My Profile";
}

@section Styles {
    <link rel="stylesheet" href="~/css/doctorprofile.css" asp-append-version="true" />
}

<div class="container-fluid py-4">

    @if (TempData["StatusMessage"] is string success && !string.IsNullOrWhiteSpace(success))
    {
        <div class="alert alert-success border-0 shadow-sm">@success</div>
    }
    @if (TempData["ErrorMessage"] is string error && !string.IsNullOrWhiteSpace(error))
    {
        <div class="alert alert-danger border-0 shadow-sm">@error</div>
    }

    <div class="row g-4">

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm overflow-hidden">

                <div class="p-4 bg-light">
                    <div class="d-flex align-items-center gap-3">

                        <div class="profile-avatar">
                            @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
                            {
                                <img src="@Model.ProfileImageUrl" alt="Profile photo" />
                            }
                            else
                            {
                                <div class="avatar-fallback">
                                    <i class="bi bi-person-badge"></i>
                                </div>
                            }
                        </div>

                        <div class="flex-grow-1">
                            <div class="fs-4 fw-bold text-dark">@Model.DisplayName</div>
                            <div class="text-muted">@Model.DisplaySubtitle</div>
                            <div class="small text-muted mt-1">
                                <i class="bi bi-envelope me-1"></i>@Model.Email
                            </div>
                        </div>
                    </div>

                    <div class="mt-3 d-flex flex-wrap gap-2">
                        <span class="badge bg-primary-subtle text-primary border border-primary-subtle">
                            <i class="bi bi-hospital me-1"></i>
                            @(string.IsNullOrWhiteSpace(Model.ClinicId) ? "No clinic assigned" : Model.ClinicId)
                        </span>

                        <span class="badge bg-success-subtle text-success border border-success-subtle">
                            <i class="bi bi-check2-circle me-1"></i>Verified Doctor
                        </span>
                    </div>
                </div>

                <div class="card-body p-4">
                    <div class="row g-3">

                        <div class="col-6">
                            <div class="stat-mini">
                                <div class="stat-label">Appointments</div>
                                <div class="stat-value">@Model.StatsAppointments</div>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="stat-mini">
                                <div class="stat-label">Patients</div>
                                <div class="stat-value">@Model.StatsPatients</div>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="stat-mini">
                                <div class="stat-label">Pending Documents</div>
                                <div class="stat-value">@Model.StatsPendingAttachments</div>
                            </div>
                        </div>

                        <div class="col-6">
                            <div class="stat-mini">
                                <div class="stat-label">Unread Messages</div>
                                <div class="stat-value">@Model.StatsUnreadMessages</div>
                            </div>
                        </div>

                    </div>

                    <hr class="my-4" />

                    <form method="post" enctype="multipart/form-data" asp-page-handler="UploadPhoto">
                        @Html.AntiForgeryToken()

                        <div class="mb-2 fw-semibold text-dark">Profile Photo</div>
                        <div class="small text-muted mb-3">Allowed formats: PNG, JPG, JPEG, WEBP. Max size: 2MB.</div>

                        <input asp-for="PhotoFile" type="file" class="form-control" accept=".png,.jpg,.jpeg,.webp" />
                        <span asp-validation-for="PhotoFile" class="text-danger small"></span>

                        <div class="d-flex gap-2 mt-3">
                            <button type="submit" class="btn btn-outline-primary">
                                <i class="bi bi-upload me-2"></i>Upload
                            </button>

                            @if (!string.IsNullOrWhiteSpace(Model.ProfileImageUrl))
                            {
                                <button type="submit" class="btn btn-outline-danger" asp-page-handler="RemovePhoto">
                                    <i class="bi bi-trash me-2"></i>Remove
                                </button>
                            }
                        </div>
                    </form>

                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">

                <div class="card-header bg-transparent border-0 px-4 pt-4 pb-0">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-4 fw-bold text-dark">Doctor Profile</div>
                            <div class="text-muted">Keep your profile professional and up to date.</div>
                        </div>

                        <a asp-page="/Doctor/Index" class="btn btn-sm btn-light">
                            <i class="bi bi-arrow-left me-2"></i>Back
                        </a>
                    </div>

                    <ul class="nav nav-pills mt-4">
                        <li class="nav-item">
                            <button class="nav-link active" data-bs-toggle="pill" data-bs-target="#account">
                                <i class="bi bi-person-lines-fill me-2"></i>Account
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#professional">
                                <i class="bi bi-award me-2"></i>Professional
                            </button>
                        </li>

                        <li class="nav-item">
                            <button class="nav-link" data-bs-toggle="pill" data-bs-target="#office">
                                <i class="bi bi-geo-alt me-2"></i>Bio & Office
                            </button>
                        </li>
                    </ul>
                </div>

                <div class="card-body p-4">
                    <form method="post">
                        @Html.AntiForgeryToken()

                        <div class="tab-content">

                            
                            <div class="tab-pane fade show active" id="account">
                                <div class="row g-3">

                                    <div class="col-md-7">
                                        <label class="form-label">Full Name</label>
                                        <input asp-for="Input.FullName" class="form-control" />
                                        <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                                    </div>

                                    <div class="col-md-5">
                                        <label class="form-label">Email</label>
                                        <input class="form-control" value="@Model.Email" disabled />
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">Phone Number</label>
                                        <input asp-for="Input.PhoneNumber" class="form-control" />
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">Clinic ID</label>
                                        <input class="form-control" value="@Model.ClinicId" disabled />
                                    </div>

                                </div>
                            </div>

                            
                            <div class="tab-pane fade" id="professional">
                                <div class="row g-3">

                                    <div class="col-md-6">
                                        <label class="form-label">Specialty</label>
                                        <input asp-for="Input.Specialty" class="form-control" placeholder="e.g. Cardiology, Radiology" />
                                    </div>

                                    <div class="col-md-6">
                                        <label class="form-label">License Number</label>
                                        <input asp-for="Input.LicenseNumber" class="form-control" placeholder="e.g. MED-123456" />
                                    </div>

                                    <div class="col-12">
                                        <label class="form-label">Languages</label>
                                        <input asp-for="Input.Languages" class="form-control" placeholder="e.g. English, Spanish" />
                                    </div>

                                </div>
                            </div>

                            
                            <div class="tab-pane fade" id="office">
                                <div class="row g-3">

                                    <div class="col-12">
                                        <label class="form-label">Biography</label>
                                        <textarea asp-for="Input.Bio" class="form-control" rows="5" placeholder="Write a short professional biography..."></textarea>
                                    </div>

                                    <div class="col-md-8">
                                        <label class="form-label">Office Address</label>
                                        <input asp-for="Input.OfficeAddress" class="form-control" placeholder="Street and number..." />
                                    </div>

                                    <div class="col-md-4">
                                        <label class="form-label">City</label>
                                        <input asp-for="Input.City" class="form-control" placeholder="e.g. New York" />
                                    </div>

                                </div>
                            </div>

                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary px-4">
                                <i class="bi bi-save me-2"></i>Save Profile
                            </button>
                        </div>

                    </form>
                </div>
            </div>

            
            <div class="card border-0 shadow-sm mt-4">
                <div class="card-body p-4">
                    <div class="fw-bold text-dark">Public Profile Preview</div>

                    <div class="text-muted mt-1">
                        <span class="me-3">
                            <i class="bi bi-award me-1"></i>
                            @(string.IsNullOrWhiteSpace(Model.Input.Specialty) ? "No specialty set" : Model.Input.Specialty)
                        </span>

                        <span>
                            <i class="bi bi-translate me-1"></i>
                            @(string.IsNullOrWhiteSpace(Model.Input.Languages) ? "No languages set" : Model.Input.Languages)
                        </span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/doctorprofile.js" asp-append-version="true"></script>
}