@page
@model Licenta.Pages.Doctor.Schedule.IndexModel
@{
    ViewData["Title"] = "My Schedule";
    bool hasSchedule = Model.SavedIntervals.Any();
}

@section Styles {
    <link rel="stylesheet" href="~/css/doctor.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ScheduleDR.css" asp-append-version="true" />
}

<div class="schedule-page">
    <div class="container py-4">
        <div class="schedule-hero mb-4">
            <div class="schedule-hero-left">
                <div class="schedule-badge">
                    <i class="bi bi-calendar2-week"></i>
                    <span>Doctor Workspace</span>
                </div>
                <h2 class="schedule-title mb-1">My Schedule</h2>
                <div class="schedule-subtitle">Multi-slot support active. Define breaks by adding multiple lines for the same day.</div>
            </div>
            <div class="schedule-hero-right">
                <div class="schedule-stats">
                    <div class="stat-card">
                        <div class="stat-icon"><i class="bi bi-clock-history"></i></div>
                        <div class="stat-body">
                            <div class="stat-label">Total Slots</div>
                            <div class="stat-value">@Model.SavedIntervals.Count</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        @if (TempData["StatusMessage"] is string status)
        {
            <div class="alert alert-success border-0 shadow-sm mb-4">@status</div>
        }

        <div class="row g-4">
            <div class="col-12 col-lg-7">
                <div class="card schedule-card shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="schedule-card-header">
                            <div class="schedule-card-title"><i class="bi bi-pencil-square"></i> Editor</div>
                            <button type="button" class="btn btn-sm btn-outline-secondary" id="btnInsertExample">Insert Example</button>
                        </div>
                        <form method="post" class="mt-3">
                            <div class="mb-3">
                                <textarea asp-for="ScheduleText" class="form-control schedule-textarea" rows="10"
                                          placeholder="Monday 08:00 - 12:00&#10;Monday 14:00 - 18:00"></textarea>
                                <span asp-validation-for="ScheduleText" class="text-danger"></span>
                            </div>
                            <div class="d-flex gap-2">
                                <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Save Schedule</button>
                                <a asp-page="/Doctor/Index" class="btn btn-outline-secondary">Back</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>

            <div class="col-12 col-lg-5">
                <div class="card schedule-card shadow-sm h-100">
                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="schedule-card-title m-0"><i class="bi bi-calendar-check"></i> Current Schedule</div>
                            <div class="d-flex gap-2">
                                @if (hasSchedule)
                                {
                                    <button class="btn btn-sm btn-outline-primary" onclick="document.getElementById('ScheduleText').focus()">Edit</button>
                                    <form method="post" asp-page-handler="Clear"><button class="btn btn-sm btn-outline-danger">Clear</button></form>
                                }
                            </div>
                        </div>

                        @if (hasSchedule)
                        {
                            <div class="table-responsive">
                                <table class="table table-sm schedule-table">
                                    <thead>
                                        <tr>
                                            <th>Day</th>
                                            <th>From</th>
                                            <th>To</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.SavedIntervals)
                                        {
                                            <tr>
                                                <td><strong>@item.DayName</strong></td>
                                                <td><span class="time-pill">@DateTime.Today.Add(item.StartTime).ToString("HH:mm")</span></td>
                                                <td><span class="time-pill">@DateTime.Today.Add(item.EndTime).ToString("HH:mm")</span></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        }
                        else
                        {
                            <div class="text-center py-5 text-muted">No schedule defined.</div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/ScheduleDR.js" asp-append-version="true"></script>
}