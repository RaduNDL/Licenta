@page
@model Licenta.Pages.Doctor.Appointments.ApprovalsModel
@{
    ViewData["Title"] = "Appointment Approvals";
}

@section Styles {
    <link rel="stylesheet" href="~/css/approvalsdr.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}

<div class="approvals-wrapper">
    <div class="approvals-container fade-in-up">
        
        <div class="approvals-header">
            <div class="header-titles">
                <h2 class="title-main">
                    <div class="icon-box">
                        <i class="bi bi-calendar-check"></i>
                    </div>
                    Appointment Approvals
                </h2>
                <p class="subtitle">Review and manage pending patient requests.</p>
            </div>
            <a asp-page="/Doctor/Index" class="btn-back">
                <i class="bi bi-arrow-left"></i>
                <span>Dashboard</span>
            </a>
        </div>

        @if (TempData["StatusMessage"] is string status)
        {
            <div class="alert alert-success">
                <i class="bi bi-check-circle-fill"></i>
                <span>@status</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>@Model.ErrorMessage</span>
            </div>
        }

        <div class="approvals-card">
            @if (Model.Items == null || !Model.Items.Any())
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <i class="bi bi-inbox"></i>
                    </div>
                    <h3>All caught up!</h3>
                    <p>There are no pending appointment requests at the moment.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="approvals-table">
                        <thead>
                            <tr>
                                <th>Patient Details</th>
                                <th>Request Info</th>
                                <th>Submitted On</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var a in Model.Items)
                            {
                                <tr class="table-row">
                                    <td>
                                        <div class="patient-info">
                                            <div class="patient-avatar">
                                                <span>@((a.Patient?.User?.FullName ?? a.Patient?.User?.Email ?? "U")[0].ToString().ToUpper())</span>
                                            </div>
                                            <div class="patient-details">
                                                <span class="patient-name">@(a.Patient?.User?.FullName ?? a.Patient?.User?.Email ?? "Unknown Patient")</span>
                                                <span class="patient-id">ID: @a.PatientId.ToString().Substring(0, 8)...</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="request-info">
                                            <span class="request-title">Appointment Request</span>
                                            @if (!string.IsNullOrWhiteSpace(a.Type))
                                            {
                                                <span class="request-badge">@a.Type</span>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <div class="date-info">
                                            <div class="date-primary">
                                                <i class="bi bi-calendar-event"></i>
                                                @a.UploadedAt.ToLocalTime().ToString("MMM dd, yyyy")
                                            </div>
                                            <div class="date-secondary">
                                                <i class="bi bi-clock"></i>
                                                @a.UploadedAt.ToLocalTime().ToString("HH:mm")
                                            </div>
                                            <span class="status-badge @(a.Status.ToString().ToLower() == "pending" ? "status-pending" : "status-default")">
                                                @a.Status
                                            </span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="action-buttons">
                                            <a class="btn-action btn-download" asp-page="/Files/Attachment" asp-route-id="@a.Id" title="Download attachment">
                                                <i class="bi bi-cloud-download"></i>
                                            </a>
                                            <a class="btn-action btn-review" asp-page="/Doctor/Appointments/ApprovalDetails" asp-route-attachmentId="@a.Id">
                                                <span>Review</span>
                                                <i class="bi bi-chevron-right"></i>
                                            </a>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/approvalsdr.js" asp-append-version="true"></script>
}