@page "{attachmentId:guid}"
@model Licenta.Pages.Doctor.Appointments.ApprovalDetailsModel
@{
    ViewData["Title"] = "Review Appointment Request";
}

@section Styles {
    <link rel="stylesheet" href="~/css/approvalsdr.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
}

<div class="approvals-wrapper">
    <div class="approvals-container fade-in-up">
        
        <div class="approvals-header">
            <div class="header-titles">
                <h2 class="title-main">
                    <div class="icon-box">
                        <i class="bi bi-file-earmark-medical"></i>
                    </div>
                    Review Request
                </h2>
                <p class="subtitle">Approve or reject the patient's appointment request.</p>
            </div>
            <a asp-page="/Doctor/Appointments/Approvals" class="btn-back">
                <i class="bi bi-arrow-left"></i>
                <span>Back to Approvals</span>
            </a>
        </div>

        @if (TempData["StatusMessage"] is string status)
        {
            <div class="alert alert-success">
                <i class="bi bi-info-circle-fill"></i>
                <span>@status</span>
            </div>
        }

        @if (!Model.CanView)
        {
            <div class="alert alert-danger">
                <i class="bi bi-exclamation-triangle-fill"></i>
                <span>You cannot view this request.</span>
            </div>
        }
        else
        {
            <div class="details-layout">
                
                <div class="detail-card main-info-card">
                    <div class="card-header-styled">
                        <i class="bi bi-info-circle"></i>
                        <h3>Request Details</h3>
                    </div>
                    
                    <div class="info-grid">
                        <div class="info-group">
                            <span class="info-label"><i class="bi bi-person"></i> Patient</span>
                            <span class="info-value fw-semibold text-main">@Model.PatientName</span>
                        </div>
                        <div class="info-group">
                            <span class="info-label"><i class="bi bi-heart-pulse"></i> Doctor</span>
                            <span class="info-value">@Model.DoctorName</span>
                        </div>
                        <div class="info-group">
                            <span class="info-label"><i class="bi bi-calendar-plus"></i> Submitted</span>
                            <span class="info-value">@Model.UploadedAtDisplay</span>
                        </div>
                        <div class="info-group">
                            <span class="info-label"><i class="bi bi-clock-history"></i> Requested slot</span>
                            <span class="info-value text-primary fw-bold">@Model.RequestedSlotDisplay</span>
                        </div>
                    </div>

                    <div class="reason-section mt-4">
                        <span class="info-label mb-2 d-block"><i class="bi bi-chat-left-text"></i> Reason</span>
                        <div class="reason-box">
                            @Model.Reason
                        </div>
                    </div>
                </div>

                <div class="actions-column">
                    <form method="post" asp-page-handler="Approve" class="action-form-card approve-card">
                        <div class="card-header-action approve-header">
                            <i class="bi bi-check-circle"></i>
                            <h4>Approve Request</h4>
                        </div>
                        <div class="card-body-action">
                            <div class="form-group custom-input mb-3">
                                <label class="form-label">Location</label>
                                <div class="input-with-icon">
                                    <i class="bi bi-geo-alt"></i>
                                    <input asp-for="Location" class="form-control" placeholder="Clinic / Office / Room..." />
                                </div>
                                <span asp-validation-for="Location" class="text-danger small-err"></span>
                            </div>

                            <div class="form-group custom-input mb-4">
                                <label class="form-label">Optional note to patient</label>
                                <div class="input-with-icon">
                                    <i class="bi bi-pencil"></i>
                                    <input asp-for="DecisionNote" id="DecisionNote_Approve" name="DecisionNote" class="form-control" placeholder="Instructions..." />
                                </div>
                                <span asp-validation-for="DecisionNote" class="text-danger small-err"></span>
                            </div>

                            <button type="submit" class="btn-submit btn-approve">
                                <i class="bi bi-check2"></i> Confirm Approval
                            </button>
                        </div>
                    </form>

                    <form method="post" asp-page-handler="Reject" class="action-form-card reject-card">
                        <div class="card-header-action reject-header">
                            <i class="bi bi-x-circle"></i>
                            <h4>Reject Request</h4>
                        </div>
                        <div class="card-body-action">
                            <div class="form-group custom-input mb-4">
                                <label class="form-label">Reason for rejection</label>
                                <div class="input-with-icon">
                                    <i class="bi bi-x-octagon"></i>
                                    <input asp-for="DecisionNote" id="DecisionNote_Reject" name="DecisionNote" class="form-control" placeholder="Explain why..." />
                                </div>
                                <span asp-validation-for="DecisionNote" class="text-danger small-err"></span>
                            </div>

                            <button type="submit" class="btn-submit btn-reject">
                                <i class="bi bi-x"></i> Reject Request
                            </button>
                        </div>
                    </form>
                </div>

            </div>
        }
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/approvalsdr.js" asp-append-version="true"></script>
}