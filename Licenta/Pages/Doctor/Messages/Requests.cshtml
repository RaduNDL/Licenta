@page
@model Licenta.Pages.Doctor.Messages.RequestsModel
@{
    ViewData["Title"] = "Doctor Requests";
}

@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/Doctor_Requests.css" asp-append-version="true" />
}

<div class="container-fluid py-4">
    <div class="row mb-4 align-items-center">
        <div class="col">
            <h2 class="page-title text-dark">
                <i class="bi bi-inbox-fill me-2 text-primary"></i>Pending Requests
            </h2>
            <p class="text-muted mb-0">Manage incoming patient consultation requests.</p>
        </div>
        <div class="col-auto">
            <a asp-page="/Doctor/Messages/Inbox" class="btn btn-outline-secondary shadow-sm">
                <i class="bi bi-arrow-left me-2"></i>Back to Inbox
            </a>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3 overflow-hidden">
        <div class="card-body p-0">
            @if (!Model.Requests.Any())
            {
                <div class="empty-state text-center py-5">
                    <div class="icon-box mb-3 bg-light text-primary mx-auto rounded-circle d-flex align-items-center justify-content-center">
                        <i class="bi bi-check-lg fs-1"></i>
                    </div>
                    <h4 class="fw-bold text-dark">All Caught Up!</h4>
                    <p class="text-muted mb-0">There are no pending requests at this time.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0 custom-table">
                        <thead class="bg-light">
                            <tr>
                                <th class="ps-4 text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Date Received</th>
                                <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Patient Info</th>
                                <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Subject</th>
                                <th class="text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Details</th>
                                <th class="text-end pe-4 text-uppercase text-secondary text-xxs font-weight-bolder opacity-7">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in Model.Requests)
                            {
                                <tr>
                                    <td class="ps-4">
                                        <div class="d-flex flex-column">
                                            <span class="fw-bold text-dark">@r.CreatedAtLocal.ToString("MMM dd, yyyy")</span>
                                            <span class="text-xs text-muted">@r.CreatedAtLocal.ToString("HH:mm")</span>
                                        </div>
                                    </td>
                                    <td>
                                        <div class="d-flex align-items-center">
                                            <div class="avatar-circle me-3 bg-primary text-white">
                                                @r.PatientName.Substring(0, 1).ToUpper()
                                            </div>
                                            <div class="d-flex flex-column">
                                                <span class="fw-bold text-dark">@r.PatientName</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-light text-dark border">@r.Subject</span>
                                    </td>
                                    <td>
                                        <p class="text-muted text-sm mb-0 text-truncate" style="max-width: 250px;" title="@r.EscalationReason">
                                            @r.EscalationReason
                                        </p>
                                    </td>
                                    <td class="text-end pe-4">
                                        <div class="d-flex justify-content-end gap-2">
                                            <form method="post" asp-page-handler="Accept" asp-route-id="@r.Id">
                                                <button class="btn btn-success btn-sm btn-icon-text shadow-sm" type="submit">
                                                    <i class="bi bi-check-circle me-1"></i> Accept
                                                </button>
                                            </form>
                                            <form method="post" asp-page-handler="Decline" asp-route-id="@r.Id" onsubmit="return confirm('Are you sure you want to decline this request?');">
                                                <button class="btn btn-danger btn-sm btn-icon-text shadow-sm" type="submit">
                                                    <i class="bi bi-x-circle me-1"></i> Decline
                                                </button>
                                            </form>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/Doctor_Requests.js" asp-append-version="true"></script>
}