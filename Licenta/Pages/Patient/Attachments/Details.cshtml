@page "{id:guid}"
@using Licenta.Models
@model Licenta.Pages.Patient.Attachments.DetailsModel

@{
    ViewData["Title"] = "Document Details";
    var item = Model.Item;
}

@if (item == null)
{
    <div class="container py-5" style="max-width: 800px;">
        <div class="mb-4">
            <a asp-page="/Patient/Attachments/Index" class="text-decoration-none text-muted">
                <i class="bi bi-arrow-left"></i> Back to My Documents
            </a>
        </div>

        <div class="alert alert-warning mb-0">
            Document not found.
        </div>
    </div>
}
else
{
    <div class="container py-5" style="max-width: 800px;">
        <div class="mb-4">
            <a asp-page="/Patient/Attachments/Index" class="text-decoration-none text-muted">
                <i class="bi bi-arrow-left"></i> Back to My Documents
            </a>
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold">Document Information</h5>
                <span class="badge @(item.Status == AttachmentStatus.Validated ? "bg-success" : (item.Status == AttachmentStatus.Rejected ? "bg-danger" : "bg-warning text-dark"))">
                    @item.Status
                </span>
            </div>
            <div class="card-body p-4">
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-bold">File Name</div>
                    <div class="col-sm-8">@item.FileName</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-bold">Type</div>
                    <div class="col-sm-8">@item.Type</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-bold">Uploaded On</div>
                    <div class="col-sm-8">@item.UploadedAt.ToLocalTime().ToString("f")</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 text-muted fw-bold">My Notes</div>
                    <div class="col-sm-8 fst-italic">"@(item.PatientNotes ?? "-")"</div>
                </div>

                <hr />

                <div class="d-flex justify-content-end">
                    <a href="@item.FilePath" target="_blank" class="btn btn-primary">
                        <i class="bi bi-download me-2"></i>Download File
                    </a>
                </div>
            </div>
        </div>

        @if (item.Status == AttachmentStatus.Validated || item.Status == AttachmentStatus.Rejected)
        {
            <div class="card shadow-sm border-0 border-start border-4 border-primary">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold mb-3 text-primary">
                        <i class="bi bi-stethoscope me-2"></i>Doctor's Feedback
                    </h5>
                    <div class="mb-3">
                        <label class="small text-muted fw-bold text-uppercase">Doctor</label>
                        <div>Dr. @(item.Doctor?.User?.FullName ?? "Unknown")</div>
                    </div>
                    <div>
                        <label class="small text-muted fw-bold text-uppercase">Notes & Observations</label>
                        <div class="p-3 bg-light rounded mt-1">
                            @if (string.IsNullOrWhiteSpace(item.DoctorNotes))
                            {
                                <span class="text-muted fst-italic">No specific notes provided.</span>
                            }
                            else
                            {
                                @item.DoctorNotes
                            }
                        </div>
                    </div>
                    <div class="mt-2 text-end text-muted small">
                        Reviewed on @(item.ValidatedAtUtc?.ToLocalTime().ToString("g") ?? "-")
                    </div>
                </div>
            </div>
        }
    </div>
}
