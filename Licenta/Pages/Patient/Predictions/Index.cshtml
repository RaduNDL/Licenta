@page
@using System.Globalization
@model Licenta.Pages.Patient.Predictions.IndexModel
@{
    ViewData["Title"] = "Predictions";
}

@section Styles {
    <link rel="stylesheet" href="~/css/PatientPredictions.css" />
}

<div class="predictions-container">
    <div class="predictions-header">
        <h2>
            <svg class="header-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.384-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" />
            </svg>
            ML Predictions
        </h2>
    </div>

    <div id="predictions-root" data-list-url="@Url.Page("/Patient/Predictions/Index", "List")">
        @if (!Model.Items.Any())
        {
            <div class="empty-state" id="empty-state">
                <p>No predictions available yet.</p>
            </div>
        }
        else
        {
            <div class="table-responsive" id="table-wrapper">
                <table class="custom-table">
                    <thead>
                        <tr>
                            <th>Model</th>
                            <th>Result</th>
                            <th>Confidence</th>
                            <th>Date</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="predictions-body">
                        @foreach (var p in Model.Items)
                        {
                            var resultText = (p.ResultLabel ?? string.Empty).Trim().ToUpperInvariant();

                            var isMalignant =
                                resultText.Contains("MALIGNANT") ||
                                resultText.Contains("CANCER") ||
                                resultText.Contains("POSITIVE");

                            var resultClass = isMalignant ? "result-cancer" : "result-safe";
                            var fillClass = isMalignant ? "confidence-cancer" : "confidence-safe";

                            var probability = p.Probability ?? 0f;
                            var percentValue = Math.Clamp((double)probability * 100d, 0d, 100d);
                            var percentDisplay = p.Probability.HasValue ? p.Probability.Value.ToString("P2") : "-";
                            var percentAttr = percentValue.ToString("0.##", CultureInfo.InvariantCulture);

                            <tr data-id="@p.Id">
                                <td data-label="Model">
                                    <span class="model-badge">@p.ModelName</span>
                                </td>

                                <td data-label="Result" data-type="result" class="@resultClass">
                                    @(string.IsNullOrWhiteSpace(p.ResultLabel) ? "-" : p.ResultLabel)
                                </td>

                                <td data-label="Confidence">
                                    <div class="confidence-meter">
                                        <span class="confidence-text">@percentDisplay</span>

                                        @if (p.Probability.HasValue)
                                        {
                                            <div class="meter-track">
                                                <div class="meter-fill @fillClass"
                                                     data-percent="@percentAttr"
                                                     style="width: 0%;"></div>
                                            </div>
                                        }
                                    </div>
                                </td>

                                <td data-label="Date" class="date-cell">
                                    @p.CreatedAtUtc.ToLocalTime().ToString("g")
                                </td>

                                <td data-label="Action" class="action-cell">
                                    <a asp-page="/Patient/Predictions/Details" asp-route-id="@p.Id" class="btn-details">
                                        View Analysis
                                        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                        </svg>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/PatientPredictions.js"></script>
}