@page
@model Licenta.Pages.Patient.Appointments.RequestModel
@{
    ViewData["Title"] = "Request Appointment";
}

@section Styles {
    <link rel="stylesheet" href="~/css/RequestAppointment.css" asp-append-version="true" />
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1 fw-bold" style="color: var(--text-main);">Online Appointment</h2>
            <p class="text-muted mb-0">Book quickly and simply in 3 steps.</p>
        </div>
        <a asp-page="/Patient/Appointments/Index"
               class="btn btn-outline-secondary exit-guard-link">
            My Appointments
        </a>
    </div>

    @if (TempData["StatusMessage"] is string status)
    {
        <div class="alert alert-info border-0 shadow-sm">@status</div>
    }

    <form method="post" id="bookingForm" novalidate>
        <input type="hidden" asp-for="Input.SelectedSlotKey" id="hiddenSlotKey" />

        <div class="row g-4">

            <div class="col-lg-4">
                <div class="wizard-step">
                    <div class="step-header">
                        <div class="step-number">1</div>
                        <h5 class="mb-0">Choose Doctor</h5>
                    </div>
                    <div id="doctorsContainer"></div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="wizard-step disabled-step" id="step2">
                    <div class="step-header">
                        <div class="step-number">2</div>
                        <h5 class="mb-0">Choose Date and Time</h5>
                    </div>

                    <div class="mb-3 fw-bold" id="selectedDoctorName"></div>

                    <div id="datesContainer" class="d-flex flex-wrap mb-3"></div>
                    <div id="timesContainer" class="d-flex flex-wrap"></div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="wizard-step disabled-step" id="step3">
                    <div class="step-header">
                        <div class="step-number">3</div>
                        <h5 class="mb-0">Visit Details</h5>
                    </div>

                    <div class="mb-4">
                        <div class="alert alert-info border-0 mb-0">
                            <i class="bi bi-calendar-check me-2"></i>
                            <span id="finalSelectionText">No time selected</span>
                        </div>
                        <span class="text-danger small mt-2 d-block"
                              asp-validation-for="Input.SelectedSlotKey"></span>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">Reason for Visit <span class="text-danger">*</span></label>
                        <textarea class="form-control"
                                  asp-for="Input.Reason"
                                  rows="4"
                                  placeholder="Briefly describe your symptoms or reason for the appointment..."></textarea>
                        <span class="text-danger" asp-validation-for="Input.Reason"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fs-6" id="submitAppointmentBtn">
                        <span class="spinner"></span>
                        <span class="btn-label">Confirm Appointment</span>
                    </button>
                </div>
            </div>

        </div>
    </form>
</div>

<div id="exitConfirmModal" class="exit-modal-backdrop" aria-hidden="true">
    <div class="exit-modal-card" role="dialog" aria-modal="true" aria-labelledby="exitModalTitle">
        <div class="exit-modal-header">
            <h3 class="exit-modal-title" id="exitModalTitle">Leave this page?</h3>
        </div>
        <div class="exit-modal-body">
            You have an unfinished appointment request. Are you sure you want to exit this page?
        </div>
        <div class="exit-modal-actions">
            <button type="button" class="btn-exit-cancel" id="stayOnPageBtn">No</button>
            <button type="button" class="btn-exit-confirm" id="leavePageBtn">Yes</button>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        const doctorsData = @Html.Raw(Model.DoctorsJson);
    </script>

    <script src="~/js/RequestAppointment.js" asp-append-version="true"></script>
}