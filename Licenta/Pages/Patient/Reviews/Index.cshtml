@page
@model Licenta.Pages.Patient.Reviews.IndexModel
@using Licenta.Models
@{
    ViewData["Title"] = "Patient Reviews";

    string StarsHtml(int rating)
    {
        var sb = new System.Text.StringBuilder();
        for (int i = 1; i <= 5; i++)
        {
            sb.Append(i <= rating
                ? "<i class='bi bi-star-fill text-warning'></i>"
                : "<i class='bi bi-star text-muted opacity-25'></i>");
        }
        return sb.ToString();
    }
}

@section Styles {
    <link rel="stylesheet" href="~/css/Review.css" asp-append-version="true" />
}

<div class="reviews-wrapper animate-fade-in">
    <div class="hero-section">
        <div class="hero-content text-center w-100">
            <h1 class="hero-title">Community Voice</h1>
            <p class="hero-subtitle">Discover and share genuine experiences from our clinic.</p>
        </div>
    </div>

    <div class="stats-container">
        <div class="stat-card">
            <div class="stat-icon bg-warning-light text-warning">
                <i class="bi bi-star-half"></i>
            </div>
            <div class="stat-info">
                <span class="stat-label">Platform Rating</span>
                <div class="stat-value">@Model.AppAverage.ToString("0.0")<span class="stat-max">/5</span></div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon bg-primary-light text-primary">
                <i class="bi bi-chat-heart"></i>
            </div>
            <div class="stat-info">
                <span class="stat-label">Total Reviews</span>
                <div class="stat-value">@Model.AppTotalCount</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon bg-success-light text-success">
                <i class="bi bi-person-hearts"></i>
            </div>
            <div class="stat-info">
                <span class="stat-label">Your Impact</span>
                <div class="stat-value">@Model.MyReviewsCount</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-2">
        <div class="col-lg-7 col-xl-8">
            <div class="control-panel mb-4">
                <ul class="nav modern-tabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-doctors" type="button">
                            <i class="bi bi-heart-pulse me-2"></i>Doctors
                            <span class="tab-badge">@Model.DoctorReviews.Count</span>
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-app" type="button">
                            <i class="bi bi-laptop me-2"></i>Platform
                            <span class="tab-badge">@Model.AppReviews.Count</span>
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-mine" type="button">
                            <i class="bi bi-person-badge me-2"></i>Personal
                        </button>
                    </li>
                </ul>

                <div class="filter-group mt-3 mt-md-0">
                    <div class="search-input-wrapper">
                        <i class="bi bi-search search-icon"></i>
                        <input type="text" id="reviewSearch" class="modern-input" placeholder="Search..." />
                    </div>
                    <select id="reviewRatingFilter" class="modern-select">
                        <option value="0">All Stars</option>
                        <option value="5">5 Stars</option>
                        <option value="4">4 Stars</option>
                        <option value="3">3 Stars</option>
                        <option value="2">2 Stars</option>
                        <option value="1">1 Star</option>
                    </select>
                </div>
            </div>

            <div class="tab-content">
                <div class="tab-pane fade show active" id="tab-doctors" role="tabpanel">
                    <div class="reviews-grid">
                        @if (Model.DoctorReviews.Count == 0)
                        {
                            <partial name="_EmptyReviews" model=' "No doctor reviews yet. Be the first to share!" ' />
                        }
                        else
                        {
                            @foreach (var r in Model.DoctorReviews)
                            {
                                var docName = r.Doctor?.User?.FullName ?? "Doctor";
                                <div class="review-card" data-rating="@r.Rating" data-date="@r.CreatedAtUtc.Ticks" data-search="@(docName + " " + (r.Title ?? "") + " " + r.Comment)">
                                    <div class="card-header-custom">
                                        <span class="custom-badge badge-doctor">Dr. @docName</span>
                                        @if (r.AuthorUserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                        {
                                            <div class="dropdown">
                                                <button class="action-btn" data-bs-toggle="dropdown" type="button"><i class="bi bi-three-dots"></i></button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                                    <li><button type="button" class="dropdown-item js-edit-review" data-id="@r.Id" data-target="@r.Target" data-doctor-id="@r.DoctorId" data-rating="@r.Rating" data-title="@(r.Title ?? "")" data-comment="@r.Comment"><i class="bi bi-pencil me-2"></i>Edit</button></li>
                                                    <li><button type="button" class="dropdown-item text-danger js-delete-review" data-id="@r.Id"><i class="bi bi-trash me-2"></i>Delete</button></li>
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                    <div class="stars-container">@Html.Raw(StarsHtml(r.Rating))</div>
                                    @if (!string.IsNullOrWhiteSpace(r.Title))
                                    {
                                        <h5 class="review-heading">@r.Title</h5>
                                    }
                                    <p class="review-body">@r.Comment</p>
                                    <div class="card-footer-custom">
                                        <div class="reviewer-avatar">@Licenta.Pages.Patient.Reviews.IndexModel.GetInitial(r.Author.FullName)</div>
                                        <div class="reviewer-info">
                                            <div class="reviewer-name">@(r.Author.FullName ?? "Patient")</div>
                                            <div class="review-date">@r.CreatedAtUtc.ToLocalTime().ToString("MMM dd, yyyy")</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="tab-pane fade" id="tab-app" role="tabpanel">
                    <div class="reviews-grid">
                        @if (Model.AppReviews.Count == 0)
                        {
                            <partial name="_EmptyReviews" model=' "No platform reviews yet." ' />
                        }
                        else
                        {
                            @foreach (var r in Model.AppReviews)
                            {
                                <div class="review-card" data-rating="@r.Rating" data-date="@r.CreatedAtUtc.Ticks" data-search="@((r.Title ?? "") + " " + r.Comment)">
                                    <div class="card-header-custom">
                                        <span class="custom-badge badge-platform">Platform Review</span>
                                        @if (r.AuthorUserId == User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                                        {
                                            <div class="dropdown">
                                                <button class="action-btn" data-bs-toggle="dropdown" type="button"><i class="bi bi-three-dots"></i></button>
                                                <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                                    <li><button type="button" class="dropdown-item js-edit-review" data-id="@r.Id" data-target="@r.Target" data-doctor-id="" data-rating="@r.Rating" data-title="@(r.Title ?? "")" data-comment="@r.Comment"><i class="bi bi-pencil me-2"></i>Edit</button></li>
                                                    <li><button type="button" class="dropdown-item text-danger js-delete-review" data-id="@r.Id"><i class="bi bi-trash me-2"></i>Delete</button></li>
                                                </ul>
                                            </div>
                                        }
                                    </div>
                                    <div class="stars-container">@Html.Raw(StarsHtml(r.Rating))</div>
                                    @if (!string.IsNullOrWhiteSpace(r.Title))
                                    {
                                        <h5 class="review-heading">@r.Title</h5>
                                    }
                                    <p class="review-body">@r.Comment</p>
                                    <div class="card-footer-custom">
                                        <div class="reviewer-avatar bg-primary text-white">@Licenta.Pages.Patient.Reviews.IndexModel.GetInitial(r.Author.FullName)</div>
                                        <div class="reviewer-info">
                                            <div class="reviewer-name">@(r.Author.FullName ?? "Patient")</div>
                                            <div class="review-date">@r.CreatedAtUtc.ToLocalTime().ToString("MMM dd, yyyy")</div>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>

                <div class="tab-pane fade" id="tab-mine" role="tabpanel">
                    <div class="reviews-grid">
                        @if (Model.MyReviews.Count == 0)
                        {
                            <partial name="_EmptyReviews" model=' "You haven&apos;t written any reviews yet." ' />
                        }
                        else
                        {
                            @foreach (var r in Model.MyReviews)
                            {
                                var isDoctor = r.Target == ReviewTarget.Doctor;
                                <div class="review-card personal-review" data-rating="@r.Rating" data-date="@r.CreatedAtUtc.Ticks" data-search="@((r.Title ?? "") + " " + r.Comment)">
                                    <div class="card-header-custom">
                                        <span class="custom-badge badge-personal">@(isDoctor ? $"Dr. {r.Doctor?.User?.FullName}" : "Platform")</span>
                                        <div class="dropdown">
                                            <button type="button" class="action-btn" data-bs-toggle="dropdown"><i class="bi bi-three-dots"></i></button>
                                            <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0">
                                                <li><button type="button" class="dropdown-item js-edit-review" data-id="@r.Id" data-target="@r.Target" data-doctor-id="@(r.DoctorId?.ToString() ?? "")" data-rating="@r.Rating" data-title="@(r.Title ?? "")" data-comment="@r.Comment"><i class="bi bi-pencil me-2"></i>Edit</button></li>
                                                <li><button type="button" class="dropdown-item text-danger js-delete-review" data-id="@r.Id"><i class="bi bi-trash me-2"></i>Delete</button></li>
                                            </ul>
                                        </div>
                                    </div>
                                    <div class="stars-container">@Html.Raw(StarsHtml(r.Rating))</div>
                                    @if (!string.IsNullOrWhiteSpace(r.Title))
                                    {
                                        <h5 class="review-heading">@r.Title</h5>
                                    }
                                    <p class="review-body">@r.Comment</p>
                                    <div class="card-footer-custom justify-content-between">
                                        <span class="badge bg-primary bg-opacity-10 text-primary px-3 py-2 rounded-pill">My Feedback</span>
                                        <span class="review-date">@r.CreatedAtUtc.ToLocalTime().ToString("MMM dd, yyyy")</span>
                                    </div>
                                </div>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-5 col-xl-4">
            <div class="form-panel sticky-top" style="top: 100px; z-index: 10;">
                <div class="form-header">
                    <h4 class="fw-bold mb-0 text-white" id="formPanelTitle">Write a Review</h4>
                    <button type="button" class="btn btn-sm btn-light rounded-circle ms-auto d-none" id="btnCancelEdit" title="Cancel Edit"><i class="bi bi-x-lg"></i></button>
                </div>

                <div class="form-body p-4">
                    <form method="post" id="reviewForm" action="?handler=Create" novalidate>
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Input.Id" id="Input_Id" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 small"></div>

                        <div class="d-flex gap-2 mb-4">
                            <label class="choice-card flex-fill" for="target-doctor">
                                <input type="radio" asp-for="Input.Target" value="Doctor" id="target-doctor" class="choice-input" checked />
                                <div class="choice-content py-3 px-2">
                                    <i class="bi bi-heart-pulse fs-4 d-block mb-1"></i>
                                    <span class="fw-bold small">Doctor</span>
                                </div>
                            </label>
                            <label class="choice-card flex-fill" for="target-app">
                                <input type="radio" asp-for="Input.Target" value="Application" id="target-app" class="choice-input" />
                                <div class="choice-content py-3 px-2">
                                    <i class="bi bi-laptop fs-4 d-block mb-1"></i>
                                    <span class="fw-bold small">Platform</span>
                                </div>
                            </label>
                        </div>

                        <div id="doctorSelectWrap" class="mb-4">
                            <label class="input-label">Consulting Doctor</label>
                            <select asp-for="Input.DoctorId" class="form-select custom-select" id="Input_DoctorId" required>
                                <option value="">Choose doctor...</option>
                                @foreach (var d in Model.AvailableDoctors)
                                {
                                    <option value="@d.Id">Dr. @d.Name (@d.Specialty)</option>
                                }
                            </select>
                            <span asp-validation-for="Input.DoctorId" class="text-danger small"></span>
                        </div>

                        <div class="rating-box mb-4 text-center">
                            <label class="input-label mb-2">Overall Satisfaction</label>
                            <div class="star-rating-control">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <input type="radio" asp-for="Input.Rating" id="rating-@i" value="@i" />
                                    <label for="rating-@i" title="@i stars"><i class="bi bi-star-fill"></i></label>
                                }
                            </div>
                            <span asp-validation-for="Input.Rating" class="text-danger small d-block mt-1"></span>
                        </div>

                        <div class="mb-4">
                            <label class="input-label">Headline</label>
                            <input asp-for="Input.Title" class="form-control custom-input" placeholder="Sum up your visit..." maxlength="120" />
                            <span asp-validation-for="Input.Title" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <div class="d-flex justify-content-between align-items-end mb-2">
                                <label class="input-label mb-0">Detailed Story</label>
                                <span class="char-counter"><span id="charCount">0</span>/2000</span>
                            </div>
                            <textarea asp-for="Input.Comment" class="form-control custom-textarea" rows="4" placeholder="What went well? What could be improved?" required></textarea>
                            <span asp-validation-for="Input.Comment" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn-submit w-100" id="reviewSubmitBtn">
                            <span data-slot="submit">Submit Feedback</span>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<form method="post" asp-page-handler="Delete" id="deleteReviewForm" class="d-none">
    @Html.AntiForgeryToken()
    <input type="hidden" name="id" id="deleteReviewId" />
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/Review.js" asp-append-version="true"></script>
}