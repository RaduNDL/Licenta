@page
@model Licenta.Pages.Patient.NotificationsModel

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-3 border-bottom">
        <h3 class="mb-0 fw-bold text-dark">My Notifications</h3>

        @if (Model.Items.Any(n => !n.IsRead))
        {
            <form method="post" asp-page-handler="MarkAllRead">
                <button class="btn btn-primary btn-sm" type="submit">Mark all as read</button>
            </form>
        }
    </div>

    @if (!Model.Items.Any())
    {
        <div class="text-center py-5 bg-light rounded text-secondary" style="border: 1px dashed #dee2e6;">
            <i class="bi bi-bell-slash" style="font-size: 3rem; opacity: 0.5;"></i>
            <h4 class="mt-3">No notifications</h4>
            <p>You are all caught up!</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-uppercase text-secondary" style="font-size: 0.85rem;">
                    <tr>
                        <th style="width:180px;">Date</th>
                        <th style="width:140px;">Type</th>
                        <th style="width:260px;">Title</th>
                        <th>Message</th>
                        <th style="width:180px;">Action</th>
                        <th style="width:120px;">State</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var n in Model.Items)
                    {
                        <tr class="@(n.IsRead ? "" : "table-primary")">
                            <td class="text-muted" style="font-size: 0.9rem; white-space: nowrap;">
                                @n.CreatedAtUtc.ToLocalTime().ToString("MMM dd, HH:mm")
                            </td>
                            <td>
                                <span class="badge bg-secondary text-uppercase" style="letter-spacing: 0.5px;">@n.Type</span>
                            </td>
                            <td class="fw-semibold text-dark">
                                @n.Title
                            </td>
                            <td class="text-dark" style="font-size: 0.95rem; line-height: 1.5;">
                                @Html.Raw(n.Message)
                            </td>
                            <td>
                                @if (!string.IsNullOrWhiteSpace(n.ActionUrl))
                                {
                                    if (n.ActionUrl.Contains("?id="))
                                    {
                                        var parts = n.ActionUrl.Split("?id=");
                                        var baseUrl = parts[0];
                                        var idValue = parts[1];

                                        <a class="btn btn-sm btn-outline-primary" href="@baseUrl/@idValue">
                                            @(string.IsNullOrWhiteSpace(n.ActionText) ? "Open" : n.ActionText)
                                        </a>
                                    }
                                    else
                                    {
                                        <a class="btn btn-sm btn-outline-primary" href="@n.ActionUrl">
                                            @(string.IsNullOrWhiteSpace(n.ActionText) ? "Open" : n.ActionText)
                                        </a>
                                    }
                                }
                            </td>
                            <td>
                                @if (!n.IsRead)
                                {
                                    <form method="post" asp-page-handler="MarkRead" class="d-inline">
                                        <input type="hidden" name="id" value="@n.Id" />
                                        <button class="btn btn-sm btn-success" type="submit">Mark read</button>
                                    </form>
                                }
                                else
                                {
                                    <span class="text-muted"><i class="bi bi-check2-all"></i> Read</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>