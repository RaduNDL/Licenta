@page
@model Licenta.Pages.Administrator.Users.CreateModel
@{
    ViewData["Title"] = "Create User";
}
@section Styles {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/create-user.css" asp-append-version="true" />
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header justify-content-center">
                    <h3 class="font-weight-light my-2 text-center">Create New Account</h3>
                </div>
                <div class="card-body p-5">
                    <form method="post" id="createUserForm" novalidate>
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                        <div class="form-floating mb-3 input-group-custom">
                            <input asp-for="Input.FullName" class="form-control" placeholder="John Doe" maxlength="256" />
                            <label asp-for="Input.FullName"><i class="bi bi-person me-2"></i>Full Name</label>
                            <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3 input-group-custom">
                            <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                            <label asp-for="Input.Email"><i class="bi bi-envelope me-2"></i>Email Address</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <div class="form-floating mb-3 input-group-custom">
                            <select asp-for="Input.Role" class="form-select" asp-items="@(new SelectList(Model.Roles))">
                                <option value="" disabled selected>Select a role...</option>
                            </select>
                            <label asp-for="Input.Role"><i class="bi bi-shield-lock me-2"></i>System Role</label>
                            <span asp-validation-for="Input.Role" class="text-danger small"></span>
                        </div>

                        <div class="input-group mb-3 password-group">
                            <div class="form-floating flex-grow-1">
                                <input asp-for="Input.Password" type="password" class="form-control" id="passwordInput" placeholder="Password" />
                                <label asp-for="Input.Password"><i class="bi bi-key me-2"></i>Password</label>
                            </div>
                            <button class="btn btn-outline-secondary" type="button" id="togglePassword" aria-label="Show or hide password">
                                <i class="bi bi-eye"></i>
                            </button>
                        </div>
                        <span asp-validation-for="Input.Password" class="text-danger small d-block mb-3"></span>

                        <div class="form-check form-switch mb-4 d-flex align-items-center">
                            <input asp-for="Input.EmailConfirmed" class="form-check-input me-3" type="checkbox" role="switch" id="emailConfirmedSwitch" style="height: 1.5rem; width: 3rem;">
                                <label class="form-check-label pt-1" for="emailConfirmedSwitch">
                                    <span class="fw-bold text-dark">Auto-confirm Email</span>
                                    <small class="text-muted d-block">User can login immediately without verification.</small>
                                </label>
                            </div>

                            <div class="d-flex align-items-center justify-content-between mt-4 mb-0">
                                <a asp-page="./Index" class="btn btn-link text-secondary text-decoration-none ps-0">
                                    <i class="bi bi-arrow-left me-1"></i> Back to List
                                </a>
                                <button type="submit" class="btn btn-primary btn-lg px-4 shadow-sm">
                                    <i class="bi bi-check2-circle me-2"></i>Create User
                                </button>
                            </div>
                        </form>
                    </div>
                    <div class="card-footer text-center py-3">
                        <div class="small text-muted">Secure user creation via Admin Portal</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    @section Scripts {
        <partial name="_ValidationScriptsPartial" />
        <script src="~/js/create-user.js" asp-append-version="true"></script>
    }