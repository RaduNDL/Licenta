@page
@model Licenta.Pages.Assistant.AssistantPanel.IndexModel
@{
    ViewData["Title"] = "Triage Center";
}

@section Styles {
    <link rel="stylesheet" href="~/css/assistantpanel.css" asp-append-version="true" />
}

<div class="container-fluid dashboard-container py-4">
    <div class="welcome-header mb-5">
        <h1 class="fw-bold">Welcome, <span class="text-primary">@Model.AssistantName</span></h1>
        <p class="text-muted"><i class="bi bi-shield-check-fill text-success me-2"></i>You are currently managing the Clinic Triage Hub.</p>
    </div>

    <div class="row g-4 mb-5">
        <div class="col-md-3">
            <div class="stat-card border-start border-4 border-danger shadow-sm p-4 bg-white rounded-3">
                <small class="text-uppercase fw-bold text-muted">New Inquiries</small>
                <h2 class="fw-bold mb-0">@Model.NewInquiriesCount</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card border-start border-4 border-primary shadow-sm p-4 bg-white rounded-3">
                <small class="text-uppercase fw-bold text-muted">In Triage</small>
                <h2 class="fw-bold mb-0">@Model.ActiveTriageCount</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card border-start border-4 border-warning shadow-sm p-4 bg-white rounded-3">
                <small class="text-uppercase fw-bold text-muted">Escalated</small>
                <h2 class="fw-bold mb-0">@Model.EscalatedToDoctorCount</h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="stat-card border-start border-4 border-info shadow-sm p-4 bg-white rounded-3">
                <small class="text-uppercase fw-bold text-muted">Unread</small>
                <h2 class="fw-bold mb-0">@Model.UnreadMessagesCount</h2>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4 d-flex justify-content-between">
                    <h5 class="fw-bold">Recent Inquiries</h5>
                    <a asp-page="/Assistant/Messages/Requests/Index" class="btn btn-sm btn-link text-decoration-none">View All</a>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0 table-hover">
                            <thead class="bg-light">
                                <tr>
                                    <th class="ps-4">Patient</th>
                                    <th>Subject</th>
                                    <th>Status</th>
                                    <th class="text-end pe-4">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var r in Model.RecentRequests)
                                {
                                    <tr>
                                        <td class="ps-4">
                                            <div class="fw-bold">@r.PatientName</div>
                                            <small class="text-muted">@r.TimeAgo</small>
                                        </td>
                                        <td>@r.Subject</td>
                                        <td>
                                            <span class="badge @(r.Status == "Pending" ? "bg-danger" : "bg-primary")">@r.Status</span>
                                        </td>
                                        <td class="text-end pe-4">
                                            <a asp-page="/Assistant/Messages/Inbox" asp-route-requestId="@r.RequestId" class="btn btn-sm btn-outline-primary rounded-pill px-3">Chat</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold">Quick Actions</h5>
                </div>
                <div class="card-body">
                    <div class="d-grid gap-2">
                        <a asp-page="/Assistant/Messages/Inbox" class="btn btn-primary py-3 fw-bold rounded-3">
                            <i class="bi bi-chat-fill me-2"></i>Open Triage Inbox
                        </a>
                        <a asp-page="/Assistant/Patients/Index" class="btn btn-light py-3 fw-bold rounded-3 border">
                            <i class="bi bi-people-fill me-2"></i>Patient Directory
                        </a>
                    </div>
                </div>
            </div>

            <div class="card border-0 shadow-sm rounded-4">
                <div class="card-header bg-transparent border-0 pt-4 px-4">
                    <h5 class="fw-bold">Recent Alerts</h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var n in Model.RecentNotifications)
                        {
                            <div class="list-group-item px-4 py-3">
                                <div class="d-flex justify-content-between mb-1">
                                    <span class="small fw-bold text-primary">@n.Type</span>
                                    <span class="extra-small text-muted">@n.TimeAgo</span>
                                </div>
                                <p class="mb-0 small">@n.Message</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>