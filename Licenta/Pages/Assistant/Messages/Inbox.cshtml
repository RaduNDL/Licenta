@page
@using System.Security.Claims
@model Licenta.Pages.Assistant.Messages.InboxModel

@{
    ViewData["Title"] = "Assistant Inbox";
    bool isChatOpen = Model.SelectedRequestId != Guid.Empty;
    var uid = User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "";
}

@section Styles {
    <link rel="stylesheet" href="~/css/messages.css" asp-append-version="true" />
}

<div class="page-container">

    @if (TempData["StatusMessage"] is string status)
    {
        <div class="alert alert-info border-0 shadow-sm mb-3">
            <i class="bi bi-info-circle me-2"></i>@status
        </div>
    }

    <div class="chat-layout @(isChatOpen ? "chat-active" : "")">

        <div class="chat-sidebar">

            <div class="sidebar-header">
                <h5 class="mb-0 fw-bold">
                    <i class="bi bi-headset text-info me-2"></i>
                    @(Model.ShowHidden ? "Hidden Inbox" : "Inbox")
                </h5>

                <div class="d-flex gap-2">
                    <a asp-page="/Assistant/Messages/Requests/Index"
                           class="btn btn-sm btn-outline-info position-relative">
                        Requests
                        @if (Model.PendingRequestsCount > 0)
                        {
                            <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                @Model.PendingRequestsCount
                            </span>
                        }
                    </a>

                    @if (!Model.ShowHidden)
                    {
                        <a asp-page="/Assistant/Messages/Inbox"
                               asp-route-showHidden="true"
                               class="btn btn-sm btn-outline-secondary"
                               title="Hidden conversations">
                            <i class="bi bi-eye-slash"></i>
                        </a>
                    }
                    else
                    {
                        <a asp-page="/Assistant/Messages/Inbox"
                               class="btn btn-sm btn-outline-secondary"
                               title="Back to visible conversations">
                            <i class="bi bi-arrow-return-left"></i>
                        </a>
                    }
                </div>
            </div>

            <div class="conversation-list">

                @if (!Model.Conversations.Any())
                {
                    <div class="text-center p-4 text-muted mt-4">
                        <i class="bi @(Model.ShowHidden ? "bi-eye-slash" : "bi-inbox") opacity-25 fs-1"></i>
                        <p class="small mt-2">
                            @(Model.ShowHidden ? "No hidden conversations." : "No active conversations.")
                        </p>
                    </div>
                }
                else
                {
                    @foreach (var c in Model.Conversations)
                    {
                        var active = c.RequestId == Model.SelectedRequestId;

                        <div class="d-flex align-items-stretch gap-2">
                            <a asp-page="/Assistant/Messages/Inbox"
                                   asp-route-requestId="@c.RequestId"
                                   asp-route-showHidden="@Model.ShowHidden"
                                   class="conversation-item flex-grow-1 @(active ? "active" : "")">

                                <div class="avatar-circle">
                                    <i class="bi bi-person-circle"></i>
                                </div>

                                <div class="conversation-info">
                                    <div class="conversation-top">
                                        <span class="conversation-name">@c.PatientName</span>
                                        <span class="conversation-meta">
                                            @c.LastAt.ToLocalTime().ToString("HH:mm")
                                        </span>
                                    </div>

                                    <div class="conversation-preview">
                                        @if (c.IsClosed)
                                        {
                                            <span class="badge bg-secondary me-1">Closed</span>
                                        }

                                        @if (c.IsHidden)
                                        {
                                            <span class="badge bg-warning text-dark me-1">Hidden</span>
                                        }

                                        @(string.IsNullOrWhiteSpace(c.LastMessagePreview)
                                            ? "Processing request..."
                                            : c.LastMessagePreview)
                                    </div>
                                </div>
                            </a>

                            @if (Model.ShowHidden && c.IsHidden)
                            {
                                <form method="post" asp-page-handler="RevealConversation" class="d-flex align-items-center">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="requestId" value="@c.RequestId" />
                                    <button type="submit"
                                            class="btn btn-link btn-sm text-success text-decoration-none px-1"
                                            title="Reveal conversation">
                                        <i class="bi bi-eye fs-5"></i>
                                    </button>
                                </form>
                            }
                            else if (c.IsClosed)
                            {
                                <form method="post" asp-page-handler="HideConversation" class="d-flex align-items-center">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="requestId" value="@c.RequestId" />
                                    <button type="submit"
                                            class="btn btn-link btn-sm text-secondary text-decoration-none px-1"
                                            title="Hide conversation"
                                            onclick="return confirm('Hide this closed conversation from your list? You can reveal it later from Hidden.');">
                                        <i class="bi bi-eye-slash fs-5"></i>
                                    </button>
                                </form>
                            }
                        </div>
                    }
                }
            </div>
        </div>

        <div class="chat-main">

            @if (!isChatOpen)
            {
                <div class="empty-state">
                    <i class="bi @(Model.ShowHidden ? "bi-eye-slash" : "bi-chat-quote-fill") text-info"></i>
                    <h4>@(Model.ShowHidden ? "Hidden conversations" : "Assistant Dashboard")</h4>
                    <p>@(Model.ShowHidden ? "Reveal a conversation to place it back in your history." : "Select a patient conversation.")</p>
                </div>
            }
            else
            {
                <div class="chat-header">

                    <div class="chat-partner-info">
                        <a asp-page="/Assistant/Messages/Inbox"
                               asp-route-showHidden="@Model.ShowHidden"
                               class="d-md-none me-3 text-dark">
                            <i class="bi bi-arrow-left fs-4"></i>
                        </a>

                        <div class="avatar-circle bg-info text-white me-3">
                            <i class="bi bi-person-fill"></i>
                        </div>

                        <div>
                            <div class="fw-bold">@Model.SelectedPatientName</div>
                            <div class="small text-muted">
                                Ref: @Model.SelectedSubject
                                @if (!Model.CanSend)
                                {
                                    <span> • Closed</span>
                                }
                            </div>
                        </div>
                    </div>

                    @if (Model.CanClose)
                    {
                        <form method="post" asp-page-handler="Close">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@Model.SelectedRequestId" />
                            <button type="submit"
                                    class="btn btn-sm btn-outline-danger"
                                    onclick="return confirm('Close this conversation? History will remain visible, but no one will be able to send new messages.');">
                                <i class="bi bi-x-lg"></i>
                            </button>
                        </form>
                    }
                </div>

                <div class="messages-container" id="chatBody">
                    @foreach (var m in Model.Messages)
                    {
                        <div class="message-row @(m.IsMine ? "mine" : "other")" data-id="@m.Id" data-utc="@m.SentAtUtc.ToString("O")">
                            <div class="message-bubble">
                                <span class="message-text">@m.Body</span>
                                <span class="message-time">@m.SentAtLocal.ToString("HH:mm")</span>
                            </div>
                        </div>
                    }
                </div>

                <div class="chat-footer">
                    <div class="chat-send-error d-none"></div>

                    @if (!Model.CanSend)
                    {
                        <div class="alert alert-warning mb-0 py-2 small text-center">
                            <i class="bi bi-lock-fill"></i> This conversation is closed. History is still available.
                        </div>
                    }
                    else
                    {
                        <form method="post"
                              data-chat-form="1"
                              data-user-id="@uid"
                              data-conversation-key="@Model.CurrentConversationKey">

                            @Html.AntiForgeryToken()

                            <input type="hidden"
                                   asp-for="Input.RequestId"
                                   value="@Model.SelectedRequestId" />

                            <div class="chat-input-wrapper">
                                <textarea asp-for="Input.NewMessageBody"
                                          class="chat-input"
                                          rows="1"
                                          placeholder="Type a message..."
                                          required></textarea>

                                <button type="submit"
                                        class="btn btn-primary btn-send">
                                    <i class="bi bi-send-fill"></i>
                                </button>
                            </div>

                            <span asp-validation-for="Input.NewMessageBody"
                                  class="text-danger small ms-2"></span>
                        </form>
                    }
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js" asp-append-version="true"></script>
    <script src="~/js/chat-inbox.js" asp-append-version="true"></script>
}